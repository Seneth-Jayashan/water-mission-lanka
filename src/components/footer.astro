---
// Import Astro's optimized Image component
import { Image } from 'astro:assets';
// Import your logo
import myLogo from '../assets/logo.png'; 
import '../styles/global.css';
---

<footer class="bg-[#03283c] border-t-[6px] border-[#37a2dd] text-gray-300 pt-12 md:pt-16 pb-6">
  <div class="container mx-auto px-6">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 mb-12">
      
      <div class="flex flex-col gap-6 text-center md:text-left items-center md:items-start">
        <div class="flex items-center gap-4">
          <Image 
            src={myLogo} 
            alt="South Corner Logo" 
            class="h-10 md:h-12 w-auto" 
            quality="high"
          />
          <span class="text-xl md:text-2xl font-bold text-white tracking-wide uppercase">
            Water Mission Lanka
          </span>
        </div>
        <p class="text-sm leading-relaxed text-gray-300 md:pr-4 max-w-sm">
          Your trusted partner for pure water solutions in Tangalle and Southern Sri Lanka. We ensure quality, safety, and health in every drop.
        </p>
      </div>

      <div class="text-center md:text-left">
        <h3 class="text-lg md:text-xl font-bold text-[#37a2dd] mb-6">Our Services</h3>
        <ul class="flex flex-col gap-4 text-sm">
          <li>
            <a href="/services" class="hover:text-white transition duration-200">Domestic Water Purification System</a>
          </li>
          <li>
            <a href="/services" class="hover:text-white transition duration-200">Industrial Water Purification System</a>
          </li>
          <li>
            <a href="/services" class="hover:text-white transition duration-200">Commercial Water Purification System</a>
          </li>
        </ul>
      </div>

      <div class="text-center md:text-left">
        <h3 class="text-lg md:text-xl font-bold text-[#37a2dd] mb-6">Contact Us</h3>
        <div class="flex flex-col gap-5 text-sm items-center md:items-start">
          
          <div class="flex items-start gap-4">
            <svg class="w-5 h-5 text-[#37a2dd] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <a href="mailto:watermissionlanka@gmail.com" class="hover:text-white transition duration-200 break-all ">watermissionlanka@gmail.com</a>
          </div>

          <div class="flex items-start gap-4 text-left">
            <svg class="w-5 h-5 text-[#37a2dd] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            <div class="flex flex-col gap-1">
              <a href="tel:+94717241720" class="hover:text-white transition duration-200">+94 71 724 1720</a>
              <a href="tel:+94707041720" class="hover:text-white transition duration-200">+94 70 704 1720</a>
            </div>
          </div>

          <div class="flex items-start gap-4 text-left">
            <svg class="w-5 h-5 text-[#37a2dd] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <span class="leading-relaxed">
              No 01, Bus Station Commercial Complex,<br>
              Main Bus Station, Tangalle. 82200
            </span>
          </div>

        </div>
      </div>
      
    </div>

    <div class="flex flex-col items-center border-t border-gray-600/50 pt-6 mt-4">
      
      <div class="flex items-center gap-6 mb-6">
        <a href="https://web.facebook.com/kenkowatermissionslanka/" aria-label="Facebook" class="text-gray-400 hover:text-white transition duration-200">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
        </a>
        <a href="#" aria-label="YouTube" class="text-gray-400 hover:text-white transition duration-200">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M19.812 5.418c.861.23 1.538.907 1.768 1.768C21.998 8.746 22 12 22 12s0 3.255-.418 4.814a2.504 2.504 0 0 1-1.768 1.768c-1.56.419-7.114.419-7.114.419s-6.255 0-7.814-.419a2.505 2.505 0 0 1-1.768-1.768C2 15.255 2 12 2 12s0-3.255.417-4.814a2.507 2.507 0 0 1 1.768-1.768C5.744 5 11.998 5 11.998 5s6.255 0 7.814.418ZM15.194 12 10 15V9l5.194 3Z" clip-rule="evenodd" /></svg>
        </a>
      </div>

      <p class="text-[10px] md:text-xs text-gray-400 tracking-wide text-center">
        © 2026 WATER MISSION (PVT) LTD. ALL RIGHTS RESERVED.
      </p>

    </div>
  </div>
</footer>