---
import Navbar from '../components/navbar.astro';
import Footer from '../components/footer.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us | Water Mission</title>
</head>
<body class="bg-[#f0f9ff] m-0 flex flex-col min-h-screen overflow-x-hidden">
    <Navbar /> 

    <main class="flex-grow max-w-7xl mx-auto px-4 md:px-6 py-12 md:py-24 w-full">
        <h1 class="text-3xl md:text-5xl font-bold text-[#004a7c] mb-8 md:mb-12 text-center lg:text-left">Contact Us</h1>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12 items-start">
            
            <div class="bg-white p-6 md:p-12 rounded-[2rem] md:rounded-[2.5rem] shadow-xl shadow-blue-100 border border-blue-50 order-1 lg:order-1">
                <h2 class="text-2xl md:text-3xl font-bold text-[#004a7c] mb-6 md:mb-8">Send a message</h2>
                
                <form id="contact-form" class="space-y-4 md:space-y-5">
                    <div class="relative">
                        <input type="text" name="from_name" placeholder="Full Name" class="w-full px-5 py-3.5 md:px-6 md:py-4 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all" required />
                    </div>
                    <div class="relative">
                        <input type="email" name="reply_to" placeholder="Email Address" class="w-full px-5 py-3.5 md:px-6 md:py-4 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all" required />
                    </div>
                    <div class="relative">
                        <input type="tel" name="phone" placeholder="Phone Number" class="w-full px-5 py-3.5 md:px-6 md:py-4 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all" required />
                    </div>
                    <div class="relative">
                        <textarea name="message" placeholder="Message" rows="5" class="w-full px-5 py-3.5 md:px-6 md:py-4 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all resize-none"></textarea>
                    </div>

                    <div id="form-status" class="hidden text-center font-medium py-2"></div>

                    <div class="flex justify-center pt-2 md:pt-4">
                        <button id="submit-btn" type="submit" class="w-full md:w-auto bg-[#0081c9] text-white px-12 py-4 rounded-xl font-bold text-lg hover:bg-[#006ba6] transition-all shadow-lg shadow-blue-100">
                            Send Message
                        </button>
                    </div>
                </form>
            </div>

            <div class="space-y-4 md:space-y-6 order-2 lg:order-2">
                <div class="bg-white p-5 md:p-6 rounded-2xl md:rounded-3xl shadow-md border border-blue-50 flex items-center gap-4 md:gap-6">
                    <div class="bg-blue-50 p-3 rounded-xl shrink-0">
                        <svg class="w-5 h-5 md:w-6 md:h-6 text-[#0081c9]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    </div>
                    <p class="text-slate-700 font-semibold text-base md:text-lg">+94 71 724 1720 / +94 70 704 1720</p>
                </div>

                <div class="bg-white p-5 md:p-6 rounded-2xl md:rounded-3xl shadow-md border border-blue-50 flex items-center gap-4 md:gap-6">
                    <div class="bg-blue-50 p-3 rounded-xl shrink-0">
                        <svg class="w-5 h-5 md:w-6 md:h-6 text-[#0081c9]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                    <p class="text-slate-700 font-semibold text-base md:text-lg break-all">watermissionlanka@gmail.com</p>
                </div>

                <div class="bg-white p-5 md:p-6 rounded-2xl md:rounded-3xl shadow-md border border-blue-100 flex items-center gap-4 md:gap-6">
                    <div class="bg-blue-50 p-3 rounded-xl shrink-0">
                        <svg class="w-5 h-5 md:w-6 md:h-6 text-[#0081c9]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </div>
                    <p class="text-slate-700 font-semibold leading-snug text-sm md:text-base">No 01, Bus Station Commercial Complex,<br/>Main Bus Station, Tangalle. 82200 Srilanka</p>
                </div>

                <div class="bg-white p-3 md:p-4 rounded-[1.5rem] md:rounded-[2rem] shadow-lg border border-blue-100 overflow-hidden h-[250px] md:h-[300px]">
                    <iframe 
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3967.7842701301824!2d80.79151607447791!3d6.024323828763877!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3ae14b8409966e95%3A0x8b36617f50746aba!2sWater%20Missions%20Lanka!5e0!3m2!1sen!2slk!4v1777018310839!5m2!1sen!2slk"
                        class="w-full h-full rounded-xl md:rounded-83637e163%3A0x6b81a79f061d471e!22xl border-0" 
                        allowfullscreen="" 
                        loading="lazy" 
                        referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
            </div>
        </div>
    </main>

    <Footer />

    <script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
    <script is:inline>
        (function() {
            emailjs.init("public_XXXXXXXXXXXXXXXX"); 
        })();

        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('contact-form');
            const statusMsg = document.getElementById('form-status');
            const submitBtn = document.getElementById('submit-btn');

            if (form) {
                form.addEventListener('submit', function(event) {
                    event.preventDefault();
                    submitBtn.innerText = "Sending...";
                    submitBtn.disabled = true;

                    emailjs.sendForm('service_id', 'template_id', this) 
                        .then(function() {
                            statusMsg.innerText = "Message sent successfully!";
                            statusMsg.className = "text-center font-medium py-2 text-green-600 block";
                            form.reset();
                            submitBtn.innerText = "Send Message";
                            submitBtn.disabled = false;
                            setTimeout(() => { statusMsg.className = "hidden"; }, 5000);
                        }, function(error) {
                            statusMsg.innerText = "Failed to send message. Please try again.";
                            statusMsg.className = "text-center font-medium py-2 text-red-600 block";
                            submitBtn.innerText = "Send Message";
                            submitBtn.disabled = false;
                        });
                });
            }
        });
    </script>
</body>
</html>