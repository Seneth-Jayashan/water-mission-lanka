---
import '../styles/global.css';
import { Image } from 'astro:assets';

// Components
import Footer from '../components/footer.astro';

// Asset Imports
import logo from '../assets/logo.png'; 
import heroImg from '../assets/hero.png';
import missionBg from '../assets/mission-Bg.png';
import martinImg from '../assets/martin.jpg';
import bryanImg from '../assets/bryan.jpg';
import janeImg from '../assets/jane.jpg';
import domesticImg from '../assets/domestic_filter.png';
import commercialImg from '../assets/commercial_filter.png';
import industrialImg from '../assets/industrial_filter.png';
import wasteTreatmentImg from '../assets/water_waste_treatment.png';

// Navbar Logic
const pathname = new URL(Astro.url).pathname;
const currentPath = pathname.replace(/\/$/, "") || "/";

const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'Products', href: '/products' },
  { name: 'About', href: '/about' },
  { name: 'Services', href: '/services' },
  { name: 'Contact', href: '/contact' },
];

const stats = [
  { 
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`, 
    value: "10+", 
    label: "YEARS EXPERIENCE" 
  },
  { 
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>`, 
    value: "5000+", 
    label: "HAPPY CUSTOMERS" 
  },
  { 
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16.36C7 10.33 12 5.26 12 5.26s5 5.07 5 11.1c0 2.76-2.24 5-5 5s-5-2.24-5-5zM12 12l.01-.01M15 10l.01-.01" /></svg>`, 
    value: "10000+", 
    label: "FILTERS INSTALLED" 
  },
  { 
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" /></svg>`, 
    value: "24/7", 
    label: "SUPPORT" 
  }
];

const categories = [
  { name: "Domestic", image: domesticImg },
  { name: "Commercial", image: commercialImg },
  { name: "Industrial", image: industrialImg },
  { name: "Water waste Treatment", image: wasteTreatmentImg },
];

const testimonials = [
  { name: "Martin Foster", role: "Homeowner", image: martinImg, text: "The water quality in our home has improved dramatically since installing the RO system." },
  { name: "Bryan Cirius", role: "Restaurant owner", image: bryanImg, text: "The water quality in our restaurant has been consistent and pure." },
  { name: "Jane Dowser", role: "Local Resident", image: janeImg, text: "Excellent customer service and very reliable equipment." },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home | Water Mission (PVT) LTD</title>
</head>
<body class="bg-white m-0 flex flex-col min-h-screen overflow-x-hidden">

    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <nav class="container mx-auto px-4 md:px-6 py-4">
        <div class="flex items-center justify-between">
          <a href="/" class="flex items-center gap-2 md:gap-4 group">
            <Image src={logo} alt="Logo" class="h-10 md:h-14 w-auto transition-transform group-hover:scale-105" format="webp" />
            <div class="flex flex-col">
            <span class="text-sm md:text-2xl font-bold text-[#800000] leading-tight uppercase">WATER MISSION LANKA</span>
              <span class="text-[10px] md:text-xs text-gray-500 tracking-wider">TANGALLE - SRI LANKA</span>
            </div>
          </a>

          <input type="checkbox" id="menu-toggle" class="hidden peer" />
          <label for="menu-toggle" class="md:hidden cursor-pointer p-2 text-gray-700">
            <svg id="hamburger" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </label>

          <div class="hidden md:flex items-center gap-8">
            <ul class="flex items-center gap-8 text-sm font-medium">
              {navLinks.map((link) => (
                <li>
                  <a href={link.href} class={`transition-colors duration-200 ${currentPath === link.href ? "text-blue-600 font-bold" : "text-gray-700 hover:text-blue-600"}`}>
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
            <a href="tel:+94717241720" class="flex items-center gap-2.5 bg-[#0081c9] text-white text-sm font-semibold px-6 py-3 rounded-full hover:bg-blue-700 transition shadow-md shadow-blue-100">
              Request Call
            </a>
          </div>

          <div class="hidden peer-checked:flex flex-col absolute top-full left-0 w-full bg-white border-b border-gray-100 p-6 gap-4 md:hidden shadow-xl z-50">
            {navLinks.map((link) => (
              <a href={link.href} class={`text-lg font-semibold border-b border-gray-50 pb-2 ${currentPath === link.href ? "text-blue-600" : "text-gray-800"}`}>
                {link.name}
              </a>
            ))}
            <a href="tel:+94717241720" class="bg-[#0081c9] text-white text-center py-3 rounded-xl font-bold mt-2">
              Call Now
            </a>
          </div>
        </div>
      </nav>
    </header>

    <main class="flex-grow">
      
      <section class="bg-blue-50 py-12 px-6 md:py-24 md:px-24 flex flex-col lg:flex-row items-center gap-12">
        <div class="flex-1 space-y-6 text-center lg:text-left">
          <span class="inline-block bg-white text-blue-600 px-4 py-1 rounded-full text-sm font-medium border border-blue-100 italic">Premium Water Solutions in Sri Lanka</span>
          <h1 class="text-4xl md:text-7xl font-bold text-slate-900 leading-tight">Pure Water, <br/> <span class="text-blue-500">Healthy Life</span></h1>
          <p class="text-slate-600 mx-auto lg:mx-0 max-w-md text-base md:text-lg">We offer free testing of your water to best determine the right service or equipment for you.</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a href="/contact" class="bg-blue-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-blue-700 transition shadow-lg shadow-blue-100 text-center">Request Call</a>
            <a href="/products" class="border border-blue-300 text-blue-600 px-8 py-4 rounded-xl font-bold hover:bg-blue-50 transition text-center">Explore Products</a>
          </div>
        </div>
        <div class="flex-1 flex justify-center w-full">
          <div class="relative overflow-hidden shadow-2xl w-full max-w-[18rem] md:max-w-[30rem] aspect-[3/4] rounded-[50%_50%_50%_50%_/_60%_60%_40%_40%] bg-[#bfdbfe]">
            <Image src={heroImg} alt="Healthy water" class="absolute bottom-0 w-full" />
          </div>
        </div>
      </section>

      <section class="bg-blue-50 py-16 border-t border-blue-100/50">
        <div class="container mx-auto grid grid-cols-2 lg:grid-cols-4 gap-8 px-6">
          {stats.map(stat => (
            <div class="flex flex-col items-center text-center space-y-3">
              <div class="text-blue-500 scale-75 md:scale-100"><Fragment set:html={stat.icon} /></div>
              <div class="text-2xl md:text-3xl font-bold text-slate-900 flex items-center">
                {stat.label === "SUPPORT" ? (
                  <span>{stat.value}</span>
                ) : (
                  <>
                    <span class="counter-value" data-target={stat.value.replace(/\D/g,'')}>0</span>
                    <span>{stat.value.replace(/[0-9]/g, '')}</span>
                  </>
                )}
              </div>
              <div class="text-[10px] md:text-[11px] font-bold text-slate-400 tracking-[0.2em] uppercase">
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="max-w-7xl mx-auto py-16 md:py-24 px-6 grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-16 items-center">
        <div class="relative order-2 lg:order-1">
          <div class="bg-[#4fbfff] p-8 md:p-14 rounded-[2rem] md:rounded-[3rem] shadow-2xl text-white relative overflow-hidden min-h-[350px] flex flex-col justify-center">
            <h2 class="text-2xl md:text-4xl font-bold mb-6">Our mission is Hydrate You!</h2>
            <div class="relative z-10 space-y-6">
              <p class="text-sm font-medium leading-relaxed">The water you drink should be <br/><span class="font-bold text-lg">great-tasting, clean and safe.</span></p>
              <div class="relative pl-6 border-l border-white/30">
                <span class="text-5xl absolute -top-4 -left-2 opacity-30 font-serif">“</span>
                <p class="text-[13px] opacity-90 leading-relaxed italic">For over 10 years, South Corner has been clarifying, softening, and treating water for customers throughout the region...</p>
              </div>
            </div>
            <Image src={missionBg} alt="decoration" class="absolute right-0 bottom-0 w-1/2 opacity-10 pointer-events-none" />
          </div>
        </div>

        <div class="space-y-6 md:space-y-8 text-center lg:text-left order-1 lg:order-2">
          <h3 class="text-[#0081c9] font-bold uppercase tracking-wider text-lg md:text-xl">Who are we?</h3>
          <h2 class="text-3xl md:text-5xl font-bold text-slate-900 leading-tight">Water Treatment Equipment Selling Company</h2>
          <p class="text-slate-600 text-base md:text-lg leading-relaxed">We are committed to protect the water resources of our nation by importing high-end water treatment units and offering sterling quality tools.</p>
          <a href="/about" class="inline-flex bg-[#0081c9] text-white px-8 py-4 rounded-xl font-bold hover:bg-[#006ba6] transition shadow-lg shadow-blue-100">More About Us →</a>
        </div>
      </section>

      <section class="bg-[#f0f4f8] py-16 md:py-24 px-6">
        <div class="max-w-7xl mx-auto text-center">
          <h2 class="text-3xl md:text-5xl font-bold text-[#004a7c] mb-12">Our Water Treatment Categories</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
            {categories.map((cat) => (
              <div class="bg-white rounded-[2rem] shadow-xl p-6 md:p-8 flex flex-col items-center hover:scale-105 transition duration-300">
                <div class="min-h-[150px] md:min-h-[200px] flex items-center justify-center mb-6">
                  <Image src={cat.image} alt={cat.name} class="max-h-[140px] md:max-h-[180px] w-auto object-contain" />
                </div>
                <p class="text-lg md:text-xl font-bold text-slate-800">{cat.name}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-16 md:py-20 px-6 bg-white">
        <div class="max-w-7xl mx-auto">
          <h2 class="text-3xl md:text-5xl font-bold text-[#004a7c] text-center mb-12">What Our Customers Say</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
            {testimonials.map((item) => (
              <div class="bg-[#d9e8f0] p-8 md:p-10 rounded-[2rem] md:rounded-[2.5rem] flex flex-col justify-between hover:scale-[1.02] transition">
                <div>
                  <div class="flex gap-1 mb-6 text-yellow-400">
                    {[...Array(5)].map(() => (
                      <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                    ))}
                  </div>
                  <p class="text-slate-800 italic mb-8 text-sm md:text-base leading-relaxed">"{item.text}"</p>
                </div>
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 md:w-14 md:h-14 rounded-full overflow-hidden border-2 border-white">
                    <Image src={item.image} alt={item.name} class="w-full h-full object-cover" />
                  </div>
                  <div>
                    <h4 class="font-bold text-slate-900 text-base md:text-lg">{item.name}</h4>
                    <p class="text-slate-500 text-xs md:text-sm">{item.role}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-16 md:py-20 px-6">
        <div class="max-w-6xl mx-auto rounded-[2rem] md:rounded-[3rem] bg-gradient-to-r from-[#53ace0] to-[#87c6e9] py-12 md:py-16 px-6 md:px-8 text-center text-white shadow-lg">
          <h2 class="text-3xl md:text-5xl font-bold mb-6 tracking-tight">Get Your Free Water Test Today</h2>
          <p class="text-white/90 text-base md:text-xl max-w-3xl mx-auto mb-10 leading-relaxed font-medium">Our specialists are ready to find the perfect system for your needs.</p>
          <div class="flex justify-center">
            <a href="tel:+94717241720" class="bg-white text-[#006ba6] px-8 md:px-10 py-3 md:py-4 rounded-2xl font-bold text-base md:text-lg hover:bg-blue-50 transition group">
              Schedule Free Test
            </a>
          </div>
        </div>
      </section>

    </main>

    <Footer />

    <script>
      function initCounters() {
        const counters = document.querySelectorAll('.counter-value');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const target = parseInt(el.getAttribute('data-target') || "0");
              const duration = 2000;
              const stepTime = 30;
              const steps = duration / stepTime;
              const increment = target / steps;
              let current = 0;
              const timer = setInterval(() => {
                current += increment;
                if (current >= target) {
                  el.innerText = target.toString();
                  clearInterval(timer);
                } else {
                  el.innerText = Math.floor(current).toString();
                }
              }, stepTime);
              observer.unobserve(el);
            }
          });
        }, { threshold: 0.5 });
        counters.forEach(counter => observer.observe(counter));
      }
      initCounters();
      document.addEventListener('astro:page-load', initCounters);
    </script>
</body>
</html>