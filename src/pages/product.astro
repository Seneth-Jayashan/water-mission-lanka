---
import '../styles/global.css';
import Navbar from '../components/navbar.astro';
import Footer from '../components/footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Product Details | Water Mission</title>
</head>
<body class="bg-[#eef8ff] m-0 flex flex-col min-h-screen overflow-x-hidden">
  <Navbar />

  <main class="flex-grow py-10 sm:py-14 px-4 sm:px-6 md:px-10">
    <div class="max-w-6xl mx-auto">
      <a href="/products" class="inline-flex items-center gap-2 text-[#006ea8] font-semibold hover:text-[#004f78] mb-6">← Back to Products</a>

      <section id="loading" class="bg-white rounded-3xl border border-[#d7ebf9] p-8">Loading product...</section>

      <section id="not-found" class="hidden bg-white rounded-3xl border border-[#f4d4d4] p-8 text-[#9f1d1d] font-semibold">
        Product not found.
      </section>

      <section id="product-shell" class="hidden bg-white rounded-3xl border border-[#d7ebf9] shadow-[0_14px_50px_rgba(0,86,135,0.08)] overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2">
          <div class="p-5 border-r border-slate-100">
            <img id="main-image" src="" alt="" class="w-full h-[320px] md:h-[420px] object-cover rounded-2xl bg-[#edf7ff]" />
            <div id="thumbs" class="mt-3 grid grid-cols-4 gap-2"></div>
          </div>
          <div class="p-6 md:p-8">
            <div id="category-badges" class="flex flex-wrap gap-2 mb-4"></div>
            <h1 id="product-name" class="text-3xl font-bold text-slate-900 mb-3"></h1>
            <p id="product-price" class="text-2xl font-bold text-[#00689f] mb-6"></p>
            <p id="product-description" class="text-slate-700 leading-relaxed"></p>
            <div class="mt-8">
              <a href="/contact" class="rounded-full bg-[#0076b6] text-white px-6 py-3 font-semibold hover:bg-[#005e91] transition">Request This Product</a>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />

  <script>
    const API_BASE = 'http://localhost:8000/api';
    const loadingEl = document.getElementById('loading');
    const notFoundEl = document.getElementById('not-found');
    const shellEl = document.getElementById('product-shell');

    function money(v) {
      return new Intl.NumberFormat('en-LK', { style: 'currency', currency: 'LKR' }).format(v || 0);
    }

    function escapeHtml(s) {
      return String(s)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function setMainImage(src, alt) {
      const main = document.getElementById('main-image');
      main.src = src || '';
      main.alt = alt || 'Product image';
    }

    async function loadProduct() {
      const productId = new URLSearchParams(location.search).get('id');
      if (!productId || !/^\d+$/.test(productId)) {
        loadingEl.classList.add('hidden');
        notFoundEl.classList.remove('hidden');
        return;
      }

      const res = await fetch(`${API_BASE}/products.php?limit=1&page=1&id=${encodeURIComponent(productId)}`);
      if (!res.ok) {
        loadingEl.classList.add('hidden');
        notFoundEl.classList.remove('hidden');
        return;
      }

      const data = await res.json();
      const list = data.products || [];
      const p = list.find((item) => String(item.id) === String(productId));
      if (!p) {
        loadingEl.classList.add('hidden');
        notFoundEl.classList.remove('hidden');
        return;
      }

      document.getElementById('product-name').textContent = p.name || 'Unnamed Product';
      document.getElementById('product-price').textContent = money(p.price);
      document.getElementById('product-description').textContent = p.description || 'No product description available.';

      const badges = document.getElementById('category-badges');
      badges.innerHTML = (p.categories || [])
        .map((c) => `<span class="inline-block text-xs px-2.5 py-1 rounded-full bg-[#edf7ff] border border-[#cfe9fb] text-[#005f92]">${escapeHtml(c.name)}</span>`)
        .join('');

      const images = (p.images && p.images.length ? p.images : [p.thumbnail]).filter(Boolean);
      setMainImage(images[0], p.name);

      const thumbs = document.getElementById('thumbs');
      thumbs.innerHTML = images.map((src, idx) => `
        <button type="button" data-src="${escapeHtml(src)}" class="rounded-xl overflow-hidden border ${idx === 0 ? 'border-[#0084cb]' : 'border-slate-200'}">
          <img src="${escapeHtml(src)}" alt="${escapeHtml(p.name)}" class="h-16 w-full object-cover" />
        </button>
      `).join('');
      thumbs.querySelectorAll('button').forEach((btn) => {
        btn.addEventListener('click', () => {
          setMainImage(btn.getAttribute('data-src'), p.name);
          thumbs.querySelectorAll('button').forEach((b) => b.classList.remove('border-[#0084cb]'));
          btn.classList.add('border-[#0084cb]');
        });
      });

      loadingEl.classList.add('hidden');
      shellEl.classList.remove('hidden');
    }

    loadProduct().catch(() => {
      loadingEl.classList.add('hidden');
      notFoundEl.classList.remove('hidden');
    });
  </script>
</body>
</html>