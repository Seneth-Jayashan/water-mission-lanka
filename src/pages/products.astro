---
import '../styles/global.css';
import { Image } from 'astro:assets'; 
import Navbar from '../components/navbar.astro';
import Footer from '../components/footer.astro';

import domesticImg from '../assets/domestic_filter.png';
import commercialImg from '../assets/commercial_filter.png';
import industrialImg from '../assets/industrial_filter.png';
import wasteImg from '../assets/water waste treatment.png';

const products = [
  { name: "Domestic", image: domesticImg },
  { name: "Commercial", image: commercialImg },
  { name: "Industrial", image: industrialImg },
  { name: "Water Waste Treatment", image: wasteImg },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products | Water Mission</title>
</head>
<body class="bg-[#f0f9ff] m-0 flex flex-col min-h-screen overflow-x-hidden">
    <Navbar /> 

<section class="bg-white py-10 sm:py-12 md:py-16 px-4 sm:px-6 md:px-10">
  <div class="max-w-7xl mx-auto">

    <!-- Heading -->
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-[#004a7c] mb-8 sm:mb-10 md:mb-12">
      Products
    </h2>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 sm:gap-6 md:gap-8">

      {products.map((product) => (
        <div class="bg-white rounded-3xl shadow-md border border-gray-100 flex flex-col p-5 sm:p-6 md:p-8 
                    transition-all duration-300 
                    hover:shadow-xl hover:-translate-y-1 active:scale-[0.98]">

          <!-- Image -->
          <div class="flex items-center justify-center min-h-[160px] sm:min-h-[200px] md:min-h-[240px] mb-4 sm:mb-5 md:mb-6">
            <Image 
              src={product.image} 
              alt={product.name} 
              class="max-h-[140px] sm:max-h-[180px] md:max-h-[200px] w-auto object-contain transition-transform duration-300 group-hover:scale-105"
            />
          </div>

          <!-- Title -->
          <div class="mt-auto border-t border-gray-100 pt-3 sm:pt-4">
            <h3 class="text-base sm:text-lg md:text-xl font-semibold text-slate-800 leading-snug">
              {product.name}
            </h3>
          </div>

        </div>
      ))}

    </div>

  </div>
</section>

<Footer />